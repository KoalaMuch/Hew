{
  "uid": "hew-system-overview",
  "title": "System Overview",
  "tags": ["hew", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{job=\"integrations/docker\", name=~\".+\"}[5m])) * 100",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Memory Usage by Container",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{job=\"integrations/docker\", name=~\".+\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Container Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "container_last_seen{job=\"integrations/docker\", name=~\".+\"} - time()",
          "format": "table",
          "instant": true,
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "name" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Last Seen (ago)" },
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": -60 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "id": true, "image": true, "instance": true, "job": true }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Network Received (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{job=\"integrations/docker\", name=~\".+\"}[5m]))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 1 }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Network Transmitted (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{job=\"integrations/docker\", name=~\".+\"}[5m]))",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 1 }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{job=\"integrations/postgres\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "PostgreSQL Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "pg_database_size_bytes{job=\"integrations/postgres\", datname!~\"template.*\"}",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "PostgreSQL Transactions / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{job=\"integrations/postgres\"}[5m]))",
          "legendFormat": "commits/s"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback{job=\"integrations/postgres\"}[5m]))",
          "legendFormat": "rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Disk Read/Write (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_fs_reads_bytes_total{job=\"integrations/docker\", name=~\".+\"}[5m]))",
          "legendFormat": "read: {{name}}"
        },
        {
          "expr": "sum by (name) (rate(container_fs_writes_bytes_total{job=\"integrations/docker\", name=~\".+\"}[5m]))",
          "legendFormat": "write: {{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Container Restart Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "changes(container_last_seen{job=\"integrations/docker\", name=~\".+\"}[24h])",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "none", "textMode": "value_and_name" }
    }
  ]
}
