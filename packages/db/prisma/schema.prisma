generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ───────────────────────────────────────────

model Session {
  id                String    @id @default(cuid())
  deviceFingerprint String?
  displayName       String    @default("Anonymous")
  avatarSeed        String    @default(cuid())
  registeredUserId  String?   @unique
  registeredUser    RegisteredUser? @relation(fields: [registeredUserId], references: [id])
  createdAt         DateTime  @default(now())
  lastActiveAt      DateTime  @default(now())

  trips         Trip[]
  itemRequests  ItemRequest[]
  travelerOffers Offer[]      @relation("TravelerOffers")
  buyerOffers    Offer[]      @relation("BuyerOffers")
  buyerOrders    Order[]      @relation("BuyerOrders")
  travelerOrders Order[]      @relation("TravelerOrders")
  chatMessages   ChatMessage[]
  reviews        Review[]     @relation("ReviewAuthor")
  receivedReviews Review[]    @relation("ReviewTarget")
  disputes       Dispute[]
  auditLogs      AuditLog[]
  posts          Post[]

  @@index([registeredUserId])
  @@index([deviceFingerprint])
}

model RegisteredUser {
  id             String    @id @default(cuid())
  email          String?   @unique
  phone          String?   @unique
  passwordHash   String?
  lineId         String?   @unique
  googleId       String?   @unique
  displayName    String
  avatarUrl      String?
  role           UserRole  @default(USER)
  kycStatus      KycStatus @default(NONE)
  kycDocumentUrl String?
  rating         Float     @default(0)
  reviewCount    Int       @default(0)
  bankAccount    Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions Session[]
}

enum UserRole {
  USER
  ADMIN
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// ─── Trips & Requests ───────────────────────────────────

model Trip {
  id            String     @id @default(cuid())
  sessionId     String
  session       Session    @relation(fields: [sessionId], references: [id])
  country       String
  city          String?
  departureDate DateTime?
  returnDate    DateTime?
  description   String?
  status        TripStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  offers    Offer[]
  chatRooms ChatRoom[] @relation("TripChatRooms")
  post      Post?

  @@index([country, status])
  @@index([sessionId])
}

enum TripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model ItemRequest {
  id          String            @id @default(cuid())
  sessionId   String
  session     Session           @relation(fields: [sessionId], references: [id])
  title       String
  description String?
  imageUrls   String[]
  countries   String[]
  maxBudget   Decimal?          @db.Decimal(12, 2)
  status      ItemRequestStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  offers    Offer[]
  chatRooms ChatRoom[] @relation("ItemRequestChatRooms")
  post      Post?

  @@index([status])
  @@index([sessionId])
}

enum ItemRequestStatus {
  OPEN
  MATCHED
  CLOSED
  CANCELLED
}

// ─── Offers ─────────────────────────────────────────────

model Offer {
  id                String      @id @default(cuid())
  tripId            String?
  trip              Trip?       @relation(fields: [tripId], references: [id])
  itemRequestId     String?
  itemRequest       ItemRequest? @relation(fields: [itemRequestId], references: [id])
  travelerSessionId String
  travelerSession   Session     @relation("TravelerOffers", fields: [travelerSessionId], references: [id])
  buyerSessionId    String
  buyerSession      Session     @relation("BuyerOffers", fields: [buyerSessionId], references: [id])
  productPrice      Decimal     @db.Decimal(12, 2)
  shippingFee       Decimal     @db.Decimal(12, 2)
  commissionFee     Decimal     @db.Decimal(12, 2)
  totalPrice        Decimal     @db.Decimal(12, 2)
  currency          String      @default("THB")
  notes             String?
  status            OfferStatus @default(PENDING)
  expiresAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  order     Order?
  chatRooms ChatRoom[] @relation("OfferChatRooms")

  @@index([itemRequestId, status])
  @@index([tripId])
  @@index([travelerSessionId])
  @@index([buyerSessionId])
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

// ─── Orders ─────────────────────────────────────────────

model Order {
  id                  String      @id @default(cuid())
  offerId             String      @unique
  offer               Offer       @relation(fields: [offerId], references: [id])
  buyerSessionId      String
  buyerSession        Session     @relation("BuyerOrders", fields: [buyerSessionId], references: [id])
  travelerSessionId   String
  travelerSession     Session     @relation("TravelerOrders", fields: [travelerSessionId], references: [id])
  buyerPhone          String?
  buyerEmail          String?
  travelerPhone       String?
  travelerEmail       String?
  travelerBankAccount Json?
  totalAmount         Decimal     @db.Decimal(12, 2)
  commissionAmount    Decimal     @db.Decimal(12, 2)
  payoutAmount        Decimal     @db.Decimal(12, 2)
  status              OrderStatus @default(CREATED)
  idempotencyKey      String      @unique
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  escrowPayment EscrowPayment?
  shipment      Shipment?
  payout        Payout?
  disputes      Dispute[]
  reviews       Review[]

  @@index([buyerSessionId])
  @@index([travelerSessionId])
  @@index([status])
}

enum OrderStatus {
  CREATED
  ESCROW_PENDING
  PAID
  PURCHASING
  SHIPPED
  DELIVERED
  PAYOUT_RELEASED
  COMPLETED
  DISPUTED
  RESOLVED_BUYER
  RESOLVED_TRAVELER
  REFUNDED
  CANCELLED
}

// ─── Payments ───────────────────────────────────────────

model EscrowPayment {
  id               String       @id @default(cuid())
  orderId          String       @unique
  order            Order        @relation(fields: [orderId], references: [id])
  amount           Decimal      @db.Decimal(12, 2)
  currency         String       @default("THB")
  paymentProvider  String       @default("omise")
  providerChargeId String?      @unique
  status           EscrowStatus @default(PENDING)
  fundedAt         DateTime?
  releasedAt       DateTime?
  refundedAt       DateTime?
  idempotencyKey   String       @unique
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
}

enum EscrowStatus {
  PENDING
  FUNDED
  RELEASED
  REFUNDED
  DISPUTED
  FAILED
}

// ─── Shipments ──────────────────────────────────────────

model Shipment {
  id             String         @id @default(cuid())
  orderId        String         @unique
  order          Order          @relation(fields: [orderId], references: [id])
  trackingNumber String?
  carrier        String?
  proofImageUrls String[]
  shippedAt      DateTime?
  deliveredAt    DateTime?
  status         ShipmentStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  FAILED
}

// ─── Payouts ────────────────────────────────────────────

model Payout {
  id              String       @id @default(cuid())
  orderId         String       @unique
  order           Order        @relation(fields: [orderId], references: [id])
  travelerSessionId String
  amount          Decimal      @db.Decimal(12, 2)
  bankAccount     Json
  providerRef     String?
  status          PayoutStatus @default(PENDING)
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
  @@index([travelerSessionId])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Disputes ───────────────────────────────────────────

model Dispute {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  raisedBySessionId String
  raisedBySession   Session  @relation(fields: [raisedBySessionId], references: [id])
  reason       String
  evidenceUrls String[]
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  EVIDENCE_REQUESTED
  RESOLVED_BUYER
  RESOLVED_TRAVELER
  CLOSED
}

// ─── Chat ───────────────────────────────────────────────

model ChatRoom {
  id            String   @id @default(cuid())
  tripId        String?
  trip          Trip?    @relation("TripChatRooms", fields: [tripId], references: [id])
  itemRequestId String?
  itemRequest   ItemRequest? @relation("ItemRequestChatRooms", fields: [itemRequestId], references: [id])
  offerId       String?
  offer         Offer?   @relation("OfferChatRooms", fields: [offerId], references: [id])
  participants  String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages ChatMessage[]

  @@index([participants])
}

model ChatMessage {
  id        String      @id @default(cuid())
  roomId    String
  room      ChatRoom    @relation(fields: [roomId], references: [id])
  senderId  String
  sender    Session     @relation(fields: [senderId], references: [id])
  content   String
  imageUrl  String?
  type      MessageType @default(TEXT)
  readAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  OFFER_CARD
  SYSTEM
}

// ─── Reviews ────────────────────────────────────────────

model Review {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id])
  reviewerSessionId String
  reviewerSession   Session @relation("ReviewAuthor", fields: [reviewerSessionId], references: [id])
  revieweeSessionId String
  revieweeSession   Session @relation("ReviewTarget", fields: [revieweeSessionId], references: [id])
  rating          Int
  comment         String?
  createdAt       DateTime @default(now())

  @@unique([orderId, reviewerSessionId])
  @@index([revieweeSessionId])
}

// ─── Posts ──────────────────────────────────────────

model Post {
  id            String     @id @default(cuid())
  sessionId     String
  session       Session    @relation(fields: [sessionId], references: [id])
  type          PostType
  content       String     @db.Text
  hashtags      String[]
  imageUrls     String[]
  tripId        String?    @unique
  trip          Trip?      @relation(fields: [tripId], references: [id])
  itemRequestId String?    @unique
  itemRequest   ItemRequest? @relation(fields: [itemRequestId], references: [id])
  country       String?
  city          String?
  travelDate    DateTime?
  budget        Decimal?   @db.Decimal(12, 2)
  status        PostStatus @default(ACTIVE)
  viewCount     Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([type, status])
  @@index([sessionId])
  @@index([country])
  @@index([createdAt(sort: Desc)])
}

model PostHashtag {
  id    String @id @default(cuid())
  name  String @unique
  count Int    @default(0)

  @@index([count(sort: Desc)])
}

enum PostType {
  RUBHEW
  HAKHONG
}

enum PostStatus {
  ACTIVE
  CLOSED
  DELETED
}

// ─── Audit ──────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id])
  action    String
  entity    String
  entityId  String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([sessionId])
  @@index([createdAt])
}
