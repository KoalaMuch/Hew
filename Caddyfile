# Caddyfile for Hew (หิ้ว)
# Place this at /etc/caddy/Caddyfile on your VPS
# Then restart Caddy: sudo systemctl restart caddy

rubhew.com {
	reverse_proxy localhost:3001 {
		lb_try_duration 5s
		lb_retry_match method GET HEAD
	}
}

www.rubhew.com {
	redir https://rubhew.com{uri} permanent
}

api.rubhew.com {
	reverse_proxy localhost:3000 {
		lb_try_duration 5s
		lb_retry_match method GET HEAD POST PUT PATCH DELETE
		health_uri /api/health
		health_interval 5s
		health_timeout 3s
	}
}

# ─── Grafana UI (owner-only via Cloudflare Access) ───────
grafana.rubhew.com {
	reverse_proxy localhost:3002
}

# ─── Telemetry ingest (public but restricted) ────────────
telemetry.rubhew.com {
	@collect {
		method POST OPTIONS
		path /collect*
	}
	reverse_proxy @collect localhost:12347

	# Block everything that isn't POST/OPTIONS to /collect
	respond "Not Found" 404
}
