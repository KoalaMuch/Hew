# Production Environment Variables
# Copy this to .env.production and fill in real values

# Database (will be overridden by docker-compose.prod.yml internal networking)
POSTGRES_USER=hew_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hew_prod
DATABASE_URL=postgresql://hew_prod:CHANGE_ME_STRONG_PASSWORD@postgres:5432/hew_prod

# Redis (will be overridden by docker-compose.prod.yml internal networking)
REDIS_URL=redis://redis:6379

# Application
FRONTEND_URL=https://yourdomain.com
PORT=3000
NODE_ENV=production

# Omise Payment Gateway (get from https://dashboard.omise.co)
OMISE_PUBLIC_KEY=pkey_live_xxx
OMISE_SECRET_KEY=skey_live_xxx

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
